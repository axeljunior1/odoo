<odoo>
    <record id="res_config_settings_auto_barcode" model="ir.ui.view">
        <field name="name">res.config.settings.auto.barcode</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//form" position="inside">
                <app name="auto_barcode" string="Automatic Barcode">
                    <block title="Automatic Barcode">
                        <setting string="Automatic Barcode"
                                 help="Automatic rules applied when creating new products.">

                            <field name="auto_barcode_enabled"/>

                            <div class="text-muted">
                                When enabled, Odoo will automatically generate a unique barcode
                                for each new <b>stockable product</b> that does not already have one.
                            </div>

                            <field name="auto_barcode_prefix"
                                   placeholder="Example: 20"/>

                            <div class="text-muted">
                                Numeric prefix added before the generated sequence.
                                Useful to identify barcodes generated by Odoo.
                            </div>

                        </setting>

                    </block>
                    <block title="Automatic add product in PoS">
                        <setting string="Automatic add product in PoS" help="A la creation des produit, il ajoute automatiquement au Pdv">
                            <field name="auto_pos_enabled"/>

                            <div class="text-muted">
                                If enabled, all newly created products will automatically be
                                available in the Point of Sale.
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>

        </field>
    </record>
</odoo>
